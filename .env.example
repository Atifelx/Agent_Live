# ===========================================
# ENVIRONMENT VARIABLES FOR VERCEL DEPLOYMENT
# ===========================================
# Add ALL of these to your Vercel project:
# Dashboard → Your Project → Settings → Environment Variables

# 1. OpenRouter API Key (Required for AI responses)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 2. Pinecone API Key (Required for vector search)
# Get from: https://www.pinecone.io/ → API Keys
PINECONE_API_KEY=your_pinecone_api_key_here

# 3. Pinecone Index Name (Required)
# Must match the index you created in Pinecone dashboard
# Dimensions: 1024 (for llama-text-embed-v2)
# Metric: cosine
PINECONE_INDEX_NAME=your-index-name-here

# 4. Tavily API Key (Required for live web search)
# Get from: https://app.tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here
