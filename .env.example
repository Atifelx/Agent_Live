# ===========================================
# ENVIRONMENT VARIABLES FOR VERCEL DEPLOYMENT
# ===========================================

# 1. Google Gemini API Key (FREE - Required)
# Get from: https://ai.google.dev/
# Click "Get API Key" and copy
GOOGLE_API_KEY=your_google_api_key_here

# 2. Pinecone API Key (FREE - Required)
# Get from: https://www.pinecone.io/
# Sign up, create a project, copy API key from dashboard
PINECONE_API_KEY=your_pinecone_api_key_here

# 3. Pinecone Index Name (FREE - Required)
# Create an index in Pinecone dashboard
# Name: rag-chatbot (or any name you choose)
# Dimensions: 768 (for Google Gemini embeddings)
# Metric: cosine
PINECONE_INDEX_NAME=rag-chatbot

# 4. Pinecone Environment (Optional - usually auto-detected)
# Found in Pinecone dashboard (e.g., "us-east-1-aws")
PINECONE_ENVIRONMENT=your_pinecone_environment_here
